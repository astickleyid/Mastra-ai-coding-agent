{
  "name": "personal-desktop-sandbox",
  "version": "1.0.0",
  "description": "A personal desktop sandbox with a coding agent inside.",
  "main": "dist/main.js",
  "scripts": {
    "start": "npm run build:esbuild && electron .",
    "build": "npm run build:esbuild && electron-builder",
    "build:electron": "npx tsc -p tsconfig.electron.json",
    "build:esbuild": "npx esbuild electron/main.ts electron/preload.ts --bundle --platform=node --outdir=dist --external:electron && cp electron/index.html dist/index.html"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@ai-sdk/google": "latest",
    "@e2b/code-interpreter": "^1.5.1",
    "ai": "^5.0.38",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "electron": "^38.1.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
